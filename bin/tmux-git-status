#!/bin/sh
branch=$(git -C "$1" rev-parse --abbrev-ref HEAD 2>/dev/null)
if [ -n "$branch" ]; then
  folder=$(basename "$1")
  max=30
  # visible length: folder + " git:(" + branch + ")"
  total=$(( ${#folder} + 7 + ${#branch} ))
  if [ $total -gt $max ]; then
    avail=$(( max - ${#folder} - 7 - 1 ))
    if [ $avail -gt 0 ]; then
      branch="…$(printf "%s" "$branch" | tail -c $avail)"
    else
      branch="…"
    fi
  fi
  printf "#[fg=colour15]git:(%s)" "$branch"
fi
